# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Notion ──────────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_TASKS_DATABASE_ID=       # Notion database ID for tasks
NOTION_PROJECTS_DATABASE_ID=    # Notion database ID for projects (optional)

# ─── Google Calendar ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_CALENDAR_ID=primary      # "primary" or specific calendar ID

# ─── Apple Calendar (CalDAV) ─────────────────────────────────
# For iCloud CalDAV:
APPLE_CALDAV_URL=https://caldav.icloud.com/
APPLE_CALDAV_USERNAME=          # Apple ID email
APPLE_CALDAV_PASSWORD=          # App-specific password
APPLE_CALENDAR_NAME=schedule-agent

# ─── Notification ────────────────────────────────────────────
NOTIFICATION_INTERVAL_HOURS=3   # Check interval in hours
NOTIFICATION_METHOD=desktop     # desktop | slack | webhook
SLACK_WEBHOOK_URL=              # Only if NOTIFICATION_METHOD=slack
WEBHOOK_NOTIFY_URL=             # Only if NOTIFICATION_METHOD=webhook

# ─── MCP 동기화 모드 ─────────────────────────────────────────
# Claude Code의 Notion MCP / Google Calendar MCP를 사용할 경우 true (API 키 불필요)
USE_MCP_NOTION=true
USE_MCP_GCAL=true
NOTION_PARENT_PAGE_ID=      # MCP로 페이지 만들 Notion 상위 페이지 ID (DB ID 없을 때)

# ─── App Settings ────────────────────────────────────────────
DATABASE_URL=sqlite:///./schedule_agent.db
TIMEZONE=Asia/Seoul
WORK_START_HOUR=9               # Work day start (24h)
WORK_END_HOUR=22                # Work day end (24h)
DAILY_CAPACITY_HOURS=8          # Default daily available hours
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
